import pytest
from app import app

# A fixture sets up reusable test data or test objects.
@pytest.fixture
def client():
    app.config["TESTING"] = True
    with app.test_client() as client:
        yield client

def test_ping_returns_pong(client):
    response = client.get("/ping")

    assert response.status_code == 200
    assert response.get_json() == {"message": "pong"}

def test_add_returns_sum(client):
    response = client.post("/add", json={"a": 2, "b": 3})

    assert response.status_code == 200
    assert response.get_json() == {"result": 5}

def test_add_missing_values_returns_400(client):
    response = client.post("/add", json={"a": 2})

    assert response.status_code == 400
    assert response.get_json() == {"error": "Missing a or b"}